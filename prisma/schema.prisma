// Configuration du générateur du client Prisma
generator client {
  provider = "prisma-client-js"
}

// Source de données : MySQL
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enum des rôles disponibles dans l'application
enum Role {
  participant  // Utilisateur standard
  brand        // Représentant d'une marque (peut avoir plusieurs quizmasters)
  quizmaster   // Maître de quiz (doit être lié à un utilisateur avec rôle "brand")
  admin        // Administrateur système
}

// Modèle utilisateur principal
model User {
  id            Int      @id @default(autoincrement())                    // Identifiant unique auto-incrémenté
  email         String   @unique                                          // Email unique (utilisé pour la connexion)
  password      String                                                    // Mot de passe hashé (bcrypt)
  role          Role     @default(participant)                            // Rôle par défaut : participant
  brandId       Int?                                                      // ID de l'utilisateur brand (si rôle = quizmaster)
  brand         User?    @relation("quizmasterToBrand", fields: [brandId], references: [id]) // Relation vers le brand
  quizmasters   User[]   @relation("quizmasterToBrand")                   // Quizmasters associés à ce brand
  createdAt     DateTime @default(now())                                  // Date de création automatique

  @@map("users") // Nom de la table en base de données
}